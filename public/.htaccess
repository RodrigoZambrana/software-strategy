DirectoryIndex index.html

<Files "contact-config.php">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</Files>

<IfModule mod_expires.c>
  ExpiresActive On

  ExpiresByType text/html "access plus 5 minutes"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType application/json "access plus 1 day"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(?:css|js|mjs|jpg|jpeg|png|webp|svg|ico|woff|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(?:html)$">
    Header set Cache-Control "public, max-age=300"
  </FilesMatch>

  <FilesMatch "\.(?:php)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Canonical domain: force HTTPS and non-www (software-strategy.com)
  # Consider proxies (X-Forwarded-Proto) and avoid multi-hop redirects.
  RewriteCond %{ENV:REDIRECT_STATUS} ^$
  RewriteCond %{HTTP_HOST} !^software-strategy\.com$ [NC,OR]
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^(.*)$ https://software-strategy.com/$1 [L,R=301]

  # Canonical URL format: remove .html from direct requests
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html(?:[\s?]|$) [NC]
  RewriteRule ^ %1 [R=301,L]

  # Core strategic redirects
  RewriteRule ^(marketing-social|digital-marketing)/?$ services/digital-marketing [R=301,L]
  RewriteRule ^en/(marketing-social|digital-marketing)/?$ en/services/digital-marketing [R=301,L]
  RewriteRule ^web-development/?$ desarrollo-sitios-web-uruguay [R=301,L]
  RewriteRule ^crear-sitio-web-montevideo/?$ crear-sitio-web-uruguay [R=301,L]
  RewriteRule ^custom-software/?$ desarrollo-software-medida-uruguay [R=301,L]
  RewriteRule ^en/web-development/?$ en/services/web-development [R=301,L]
  RewriteRule ^en/custom-software/?$ en/services/custom-software [R=301,L]
  RewriteRule ^services/web-development/?$ desarrollo-sitios-web-uruguay [R=301,L]
  RewriteRule ^services/custom-software/?$ desarrollo-software-medida-uruguay [R=301,L]

  # Legacy URLs detected in Search Console (404/500)
  RewriteRule ^contacto/?$ contact [R=301,L]
  RewriteRule ^contacto/contacto/?$ contact [R=301,L]
  RewriteRule ^service-details/?$ services [R=301,L]
  RewriteRule ^en/service-details/?$ en/services [R=301,L]
  RewriteRule ^blog-details/?$ faqs [R=301,L]
  RewriteRule ^en/services/seo-sem/?$ en/services/google-seo [R=301,L]

  # Duplicate path normalization
  RewriteRule ^(pricing|faqs|contact|about)/\1/?$ $1 [R=301,L]
  RewriteRule ^en/(pricing|contact)/\1/?$ en/$1 [R=301,L]
  RewriteRule ^en/(pricing|contact)/en/\1/?$ en/$1 [R=301,L]
  RewriteRule ^(about|contact|faqs)/en/\1/?$ en/$1 [R=301,L]
  RewriteRule ^services/services/?$ services [R=301,L]
  RewriteRule ^en/services/(?:services|en/services)/?$ en/services [R=301,L]
  RewriteRule ^services/en/services/?$ en/services [R=301,L]
  RewriteRule ^en/en/?$ en [R=301,L]
  RewriteRule ^(services/(?:digital-marketing|google-seo))/\1/?$ $1 [R=301,L]
  RewriteRule ^services/custom-software/services/custom-software/?$ desarrollo-software-medida-uruguay [R=301,L]
  RewriteRule ^services/web-development/services/web-development/?$ desarrollo-sitios-web-uruguay [R=301,L]
  RewriteRule ^en/contact/(?:contact|en/contact)/?$ en/contact [R=301,L]
  RewriteRule ^contact/en/contact/?$ en/contact [R=301,L]

  # Special case: /services/ is a page (services.html) and also a folder for details
  RewriteRule ^services/?$ services.html [L]
  RewriteRule ^en/services/?$ en/services.html [L]

  # If language root with or without trailing slash, serve its HTML (Next export outputs en.html)
  RewriteRule ^([a-z]{2})/?$ $1.html [L]

  # If request is a directory (e.g., /en/), serve its index.html
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^(.+)/$ $1/index.html [L]

  # If not a real file or directory, try .html variant (e.g., /en -> /en.html)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+)$ $1.html [L]
</IfModule>
